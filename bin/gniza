#!/usr/bin/env bash
set -euo pipefail

# ── Resolve GNIZA_DIR ────────────────────────────────────────
GNIZA_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
export GNIZA_DIR

# ── Source libraries in dependency order ─────────────────────
source "$GNIZA_DIR/lib/constants.sh"
source "$GNIZA_DIR/lib/utils.sh"
detect_mode
source "$GNIZA_DIR/lib/logging.sh"
source "$GNIZA_DIR/lib/config.sh"
source "$GNIZA_DIR/lib/locking.sh"
source "$GNIZA_DIR/lib/targets.sh"
source "$GNIZA_DIR/lib/remotes.sh"
source "$GNIZA_DIR/lib/backup.sh"
source "$GNIZA_DIR/lib/mysql.sh"
source "$GNIZA_DIR/lib/postgresql.sh"
source "$GNIZA_DIR/lib/crontab.sh"
source "$GNIZA_DIR/lib/restore.sh"
source "$GNIZA_DIR/lib/retention.sh"
source "$GNIZA_DIR/lib/schedule.sh"
source "$GNIZA_DIR/lib/notify.sh"
source "$GNIZA_DIR/lib/ssh.sh"
source "$GNIZA_DIR/lib/rclone.sh"
source "$GNIZA_DIR/lib/snapshot.sh"
source "$GNIZA_DIR/lib/transfer.sh"
source "$GNIZA_DIR/lib/snaplog.sh"
source "$GNIZA_DIR/lib/source.sh"
source "$GNIZA_DIR/lib/health.sh"

# ── Python (prefer venv if available) ──────────────────────
if [[ -x "$GNIZA_DIR/venv/bin/python3" ]]; then
    GNIZA_PYTHON="$GNIZA_DIR/venv/bin/python3"
else
    GNIZA_PYTHON="python3"
fi
export GNIZA_PYTHON
_gniza_python_path() { command -v "$GNIZA_PYTHON"; }

# ── Help ─────────────────────────────────────────────────────
show_help() {
    cat <<EOF
gniza v${GNIZA4LINUX_VERSION} - Linux Backup Manager

Usage: gniza [OPTIONS] [COMMAND]

Options:
  --cli             Force CLI mode (no TUI)
  --debug           Enable debug logging
  --config=FILE     Override config file path
  --help            Show this help (use --full-help for detailed docs)
  --full-help       Show full documentation
  --version         Show version

Commands:
  sources           Manage sources (list, add, delete, show)
  destinations      Manage destinations (list, add, delete, show, test)
  backup            Run backup
  restore           Restore from a snapshot
  snapshots         List or browse snapshots
  retention         Enforce retention policies
  schedule          Manage cron schedules (install, show, remove)
  logs              View backup logs
  web               Web dashboard (start, install-service, status)
  daemon            Background health daemon (start, install-service, status)
  health            Health check for all destinations
  uninstall         Uninstall gniza
  update            Check for and apply updates

Run 'gniza --full-help' for detailed usage of all commands.
If no command is given, the TUI is launched.
EOF
}

show_full_help() {
    cat <<EOF
gniza v${GNIZA4LINUX_VERSION} - Linux Backup Manager

Usage: gniza [OPTIONS] [COMMAND]

Options:
  --cli             Force CLI mode (no TUI)
  --debug           Enable debug logging
  --config=FILE     Override config file path
  --help            Show short help
  --full-help       Show this full documentation
  --version         Show version

Sources (what to back up):
  sources list                          List all configured sources
  sources add --name=NAME --folders=PATHS
                                        Create a new source
  sources delete --name=NAME            Delete a source
  sources show --name=NAME              Show full source configuration

Destinations (where to store backups):
  destinations list                          List all configured destinations
  destinations add --name=NAME               Create a new destination (edit config manually or via TUI)
  destinations delete --name=NAME            Delete a destination
  destinations show --name=NAME              Show full destination configuration
  destinations test --name=NAME              Validate destination connectivity
  destinations disk-info-short --name=NAME   Show destination disk usage (used/total/free)

Operations:
  backup [--source=NAME] [--destination=NAME] [--all]
      Run backup. If no source is specified, all sources are backed up.
      Use --source=a,b,c to back up multiple sources.
      Use --destination=NAME to target a specific destination.

  restore --source=NAME --snapshot=TS [--destination=NAME] [--dest=DIR]
          [--folder=PATH] [--skip-mysql] [--skip-postgresql]
      Restore from a snapshot. Use --dest for custom restore location.
      Use --folder to restore a single directory from the snapshot.
      Use --skip-mysql to skip MySQL database restore.
      Use --skip-postgresql to skip PostgreSQL database restore.

  retention [--source=NAME] [--destination=NAME] [--count=N] [--all]
      Enforce snapshot retention policies. Deletes snapshots beyond
      the configured retention count (oldest first, pinned preserved).
      Use --count=N to override the default retention count.

Snapshots:
  snapshots list [--source=NAME] [--destination=NAME]
      List available snapshots. Filter by source and/or destination.

  snapshots browse --source=NAME --snapshot=TS [--destination=NAME]
      List all files in a specific snapshot.

Scheduling:
  schedule install      Install cron entries for all active schedules
  schedule show         Show current gniza cron entries
  schedule remove       Remove all gniza cron entries from crontab

Logs & Info:
  logs                  List all log files
  logs --last           Show the most recent backup log
  logs --last --tail=N  Show last N lines of the most recent log
  version               Show version

Web Dashboard:
  web start [--port=PORT] [--host=HOST]
      Start the web dashboard (default: port 2323, host 0.0.0.0).
      Serves the full TUI in a browser with HTTP Basic Auth.

  web install-service   Install as a systemd service (auto-starts on boot)
  web remove-service    Stop and remove the systemd service
  web status            Show service status
  web reset-password    Generate a new random login password

Background Health Daemon:
  daemon start [--interval=N]
      Start the background health daemon in foreground (default interval: from config or 10s).
      Monitors jobs, dispatches queued jobs, and cleans up old entries/logs.

  daemon install-service   Install as a systemd service (auto-starts on boot)
  daemon remove-service    Stop and remove the systemd service
  daemon status            Show service status

Health Check:
  health [--destination=NAME] [--json]
      Run comprehensive health check on all (or a specific) destination.
      Checks connectivity, disk space, snapshot counts, stale partials,
      and orphaned targets.
      Use --json for machine-readable output.

System:
  uninstall             Run the uninstall script
  update [--check] [--force]
      Check for and apply updates from the git repository.
      --check   Show available updates without applying
      --force   Force reinstall even if already up to date

Configuration:
  Sources:       \$CONFIG_DIR/targets.d/<name>.conf
  Destinations:  \$CONFIG_DIR/remotes.d/<name>.conf
  Schedules:     \$CONFIG_DIR/schedules.d/<name>.conf
  Settings:      \$CONFIG_DIR/gniza.conf

  Root mode:     /etc/gniza/
  User mode:     ~/.config/gniza/

If no command is given, the TUI is launched.
EOF
}

# ── CLI argument parsing ─────────────────────────────────────
FORCE_CLI=false
CONFIG_FILE=""
SUBCOMMAND=""
declare -a SUBCMD_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cli)
            FORCE_CLI=true
            shift
            ;;
        --debug)
            export GNIZA4LINUX_DEBUG="true"
            shift
            ;;
        --config=*)
            CONFIG_FILE="${1#--config=}"
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        --full-help|--docs)
            show_full_help
            exit 0
            ;;
        --version)
            echo "gniza v${GNIZA4LINUX_VERSION}"
            exit 0
            ;;
        -*)
            # Unknown flags before subcommand are errors
            die "Unknown option: $1 (see --help)"
            ;;
        *)
            SUBCOMMAND="$1"
            shift
            SUBCMD_ARGS=("$@")
            break
            ;;
    esac
done

# ── Initialise ───────────────────────────────────────────────
ensure_dirs

# Load config if it exists
if [[ -n "$CONFIG_FILE" ]]; then
    load_config "$CONFIG_FILE"
elif [[ -f "$CONFIG_DIR/gniza.conf" ]]; then
    load_config
fi

# Only create log files for operations that produce meaningful output
case "${SUBCOMMAND:-}" in
    backup|restore|retention|scheduled-run) init_logging ;;
esac

# ── Parse subcommand flags helper ────────────────────────────
_parse_flag() {
    local flag="$1"
    shift
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "${flag}="* ]]; then
            echo "${arg#"${flag}="}"
            return 0
        fi
    done
    return 1
}

_has_flag() {
    local flag="$1"
    shift
    local arg
    for arg in "$@"; do
        [[ "$arg" == "$flag" ]] && return 0
    done
    return 1
}

# ── CLI subcommand dispatch ──────────────────────────────────
run_cli() {
    case "${SUBCOMMAND:-}" in
        backup)
            if _has_flag "--help" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || _has_flag "-h" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || [[ "${SUBCMD_ARGS[0]:-}" == "help" ]]; then
                cat <<HELPEOF
Usage: gniza backup [OPTIONS]

Run a backup job.

Options:
  --source=NAME         Back up a specific source (comma-separated for multiple)
  --destination=NAME    Target a specific destination
  --all                 Back up all sources (default if no --source given)
  --help                Show this help

Examples:
  gniza backup                           Back up all sources to default destination
  gniza backup --source=mysite           Back up 'mysite'
  gniza backup --source=a,b,c            Back up multiple sources
  gniza backup --source=mysite --destination=offsite
HELPEOF
                exit 0
            fi
            local target="" remote="" all=false
            target=$(_parse_flag "--source" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            remote=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            _has_flag "--all" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" && all=true

            # Register in job registry so web/TUI can track CLI-started backups
            # Skip if daemon already tracks this process
            local _job_id=""
            if [[ -z "${GNIZA_DAEMON_TRACKED:-}" ]]; then
                local _job_label="Backup"
                [[ -n "$target" ]] && _job_label+=" $target"
                [[ -n "$remote" ]] && _job_label+=" → $remote"
                [[ "$all" == "true" ]] && _job_label="Backup all"
                _job_id=$(PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" "$GNIZA_DIR/lib/job_register.py" \
                    start "backup" "$_job_label" --log-file="${LOG_FILE:-}" --pid=$$ 2>/dev/null) || true
            fi
            [[ -n "${_job_id:-}" ]] && export GNIZA_JOB_ID="$_job_id"

            _finish_job_reg() {
                local _rc=$1
                local _st="success"
                (( _rc != 0 )) && _st="failed"
                if [[ -n "${_job_id:-}" ]]; then
                    PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" "$GNIZA_DIR/lib/job_register.py" \
                        finish "${_job_id}" "$_st" "$_rc" 2>/dev/null || true
                fi
            }

            trap '_gniza_exit_rc=$?; release_all_target_locks; _finish_job_reg $_gniza_exit_rc; _gniza_log_exit_trap $_gniza_exit_rc' EXIT

            if [[ "$all" == "true" || -z "$target" ]]; then
                backup_all_targets "$remote"
            elif [[ "$target" == *,* ]]; then
                local IFS=','
                local names
                read -ra names <<< "$target"
                local rc=0
                for t in "${names[@]}"; do
                    t="${t#"${t%%[![:space:]]*}"}"
                    t="${t%"${t##*[![:space:]]}"}"
                    [[ -z "$t" ]] && continue
                    backup_target "$t" "$remote" || rc=$?
                done
                exit "$rc"
            else
                backup_target "$target" "$remote"
            fi
            ;;

        restore)
            if _has_flag "--help" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || _has_flag "-h" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || [[ "${SUBCMD_ARGS[0]:-}" == "help" ]]; then
                cat <<HELPEOF
Usage: gniza restore --source=NAME --snapshot=TS [OPTIONS]

Restore from a backup snapshot.

Options:
  --source=NAME         Source to restore (required)
  --snapshot=TS         Snapshot timestamp to restore (required, or 'latest')
  --destination=NAME    Destination to restore from (default: first configured)
  --dest=DIR            Custom restore location (default: original path)
  --folder=PATH         Restore a single directory from the snapshot
  --skip-mysql          Skip MySQL database restore
  --skip-postgresql     Skip PostgreSQL database restore
  --help                Show this help

Examples:
  gniza restore --source=mysite --snapshot=latest
  gniza restore --source=mysite --snapshot=2025-03-01_120000 --dest=/tmp/restore
  gniza restore --source=mysite --snapshot=latest --folder=/var/www --skip-mysql
  gniza restore --source=mysite --snapshot=latest --skip-postgresql
HELPEOF
                exit 0
            fi
            local target="" snapshot="" remote="" dest="" folder=""
            target=$(_parse_flag "--source" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            snapshot=$(_parse_flag "--snapshot" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            remote=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            dest=$(_parse_flag "--dest" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            folder=$(_parse_flag "--folder" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true

            # Check for --skip-mysql flag
            local skip_mysql=""
            local arg
            for arg in "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}"; do
                [[ "$arg" == "--skip-mysql" ]] && skip_mysql="yes"
            done
            [[ -n "$skip_mysql" ]] && export SKIP_MYSQL_RESTORE="yes"

            # Check for --skip-postgresql flag
            local skip_postgresql=""
            for arg in "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}"; do
                [[ "$arg" == "--skip-postgresql" ]] && skip_postgresql="yes"
            done
            [[ -n "$skip_postgresql" ]] && export SKIP_POSTGRESQL_RESTORE="yes"

            [[ -z "$target" ]] && die "restore requires --source=NAME"

            if [[ -z "$remote" ]]; then
                remote=$(list_remotes | head -1)
                [[ -z "$remote" ]] && die "No destinations configured"
            fi

            if [[ -n "$folder" ]]; then
                restore_folder "$target" "$folder" "${snapshot:-latest}" "$remote" "$dest"
            else
                restore_target "$target" "${snapshot:-latest}" "$remote" "$dest"
            fi
            ;;

        sources)
            local action="${SUBCMD_ARGS[0]:-list}"
            local name="" folders=""
            name=$(_parse_flag "--name" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            folders=$(_parse_flag "--folders" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true

            case "$action" in
                help|--help|-h)
                    cat <<HELPEOF
Usage: gniza sources <action> [OPTIONS]

Manage backup sources (what to back up).

Actions:
  list                  List all configured sources (default)
  add --name=NAME --folders=PATHS
                        Create a new source
  delete --name=NAME    Delete a source
  show --name=NAME      Show full source configuration
  help                  Show this help

Examples:
  gniza sources                          List all sources
  gniza sources add --name=mysite --folders=/var/www
  gniza sources show --name=mysite
  gniza sources delete --name=mysite
HELPEOF
                    exit 0
                    ;;
                list)
                    local targets; targets=$(list_targets)
                    if [[ -z "$targets" ]]; then
                        echo "No sources configured."
                    else
                        echo "$targets"
                    fi
                    ;;
                add)
                    [[ -z "$name" ]] && die "sources add requires --name=NAME"
                    [[ -z "$folders" ]] && die "sources add requires --folders=PATHS"
                    create_target "$name" "$folders"
                    ;;
                delete)
                    [[ -z "$name" ]] && die "sources delete requires --name=NAME"
                    delete_target "$name"
                    ;;
                show)
                    [[ -z "$name" ]] && die "sources show requires --name=NAME"
                    load_target "$name"
                    echo "=== Source: $TARGET_NAME ==="
                    echo ""
                    echo "Name:           $TARGET_NAME"
                    echo "Enabled:        $TARGET_ENABLED"
                    echo "Folders:        $TARGET_FOLDERS"
                    echo "Exclude:        ${TARGET_EXCLUDE:-(none)}"
                    echo "Include:        ${TARGET_INCLUDE:-(none)}"
                    echo "Pre-hook:       ${TARGET_PRE_HOOK:-(none)}"
                    echo "Post-hook:      ${TARGET_POST_HOOK:-(none)}"
                    echo ""
                    echo "--- Source Type ---"
                    echo "Type:           $TARGET_SOURCE_TYPE"
                    case "$TARGET_SOURCE_TYPE" in
                        ssh)
                            echo "Host:           $TARGET_SOURCE_HOST"
                            echo "Port:           $TARGET_SOURCE_PORT"
                            echo "User:           $TARGET_SOURCE_USER"
                            echo "Auth method:    $TARGET_SOURCE_AUTH_METHOD"
                            if [[ "$TARGET_SOURCE_AUTH_METHOD" == "key" ]]; then
                                echo "Key:            ${TARGET_SOURCE_KEY:-(default)}"
                            else
                                echo "Password:       ****"
                            fi
                            echo "Sudo:           $TARGET_SOURCE_SUDO"
                            ;;
                        s3)
                            echo "Bucket:         $TARGET_SOURCE_S3_BUCKET"
                            echo "Region:         $TARGET_SOURCE_S3_REGION"
                            echo "Endpoint:       ${TARGET_SOURCE_S3_ENDPOINT:-(default)}"
                            echo "Access Key:     ${TARGET_SOURCE_S3_ACCESS_KEY_ID:+****}"
                            echo "Secret Key:     ${TARGET_SOURCE_S3_SECRET_ACCESS_KEY:+****}"
                            ;;
                        gdrive)
                            echo "SA File:        $TARGET_SOURCE_GDRIVE_SERVICE_ACCOUNT_FILE"
                            echo "Root Folder ID: ${TARGET_SOURCE_GDRIVE_ROOT_FOLDER_ID:-(root)}"
                            ;;
                    esac
                    if [[ "$TARGET_MYSQL_ENABLED" == "yes" ]]; then
                        echo ""
                        echo "--- MySQL ---"
                        echo "Enabled:        yes"
                        echo "Mode:           $TARGET_MYSQL_MODE"
                        echo "Databases:      ${TARGET_MYSQL_DATABASES:-(all)}"
                        echo "Exclude:        ${TARGET_MYSQL_EXCLUDE:-(none)}"
                        echo "User:           ${TARGET_MYSQL_USER:-(current)}"
                        echo "Password:       ${TARGET_MYSQL_PASSWORD:+****}"
                        echo "Host:           $TARGET_MYSQL_HOST"
                        echo "Port:           $TARGET_MYSQL_PORT"
                        echo "Extra opts:     $TARGET_MYSQL_EXTRA_OPTS"
                    fi
                    if [[ "$TARGET_POSTGRESQL_ENABLED" == "yes" ]]; then
                        echo ""
                        echo "--- PostgreSQL ---"
                        echo "Enabled:        yes"
                        echo "Mode:           $TARGET_POSTGRESQL_MODE"
                        echo "Databases:      ${TARGET_POSTGRESQL_DATABASES:-(all)}"
                        echo "Exclude:        ${TARGET_POSTGRESQL_EXCLUDE:-(none)}"
                        echo "User:           ${TARGET_POSTGRESQL_USER:-(current)}"
                        echo "Password:       ${TARGET_POSTGRESQL_PASSWORD:+****}"
                        echo "Host:           $TARGET_POSTGRESQL_HOST"
                        echo "Port:           $TARGET_POSTGRESQL_PORT"
                        echo "Extra opts:     $TARGET_POSTGRESQL_EXTRA_OPTS"
                    fi
                    ;;
                *)
                    die "Unknown sources action: $action (expected list|add|delete|show)"
                    ;;
            esac
            ;;

        destinations)
            local action="${SUBCMD_ARGS[0]:-list}"
            local name=""
            name=$(_parse_flag "--name" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true

            case "$action" in
                help|--help|-h)
                    cat <<HELPEOF
Usage: gniza destinations <action> [OPTIONS]

Manage backup destinations (where to store backups).

Actions:
  list                          List all configured destinations (default)
  add --name=NAME               Create a new destination (edit config manually or via TUI)
  delete --name=NAME            Delete a destination
  show --name=NAME              Show full destination configuration
  test --name=NAME              Validate destination connectivity
  disk-info-short --name=NAME   Show destination disk usage (used/total/free)
  help                          Show this help

Examples:
  gniza destinations                     List all destinations
  gniza destinations show --name=offsite
  gniza destinations test --name=offsite
  gniza destinations delete --name=offsite
HELPEOF
                    exit 0
                    ;;
                list)
                    local remotes; remotes=$(list_remotes)
                    if [[ -z "$remotes" ]]; then
                        echo "No destinations configured."
                    else
                        echo "$remotes"
                    fi
                    ;;
                add)
                    [[ -z "$name" ]] && die "destinations add requires --name=NAME"
                    echo "Use the TUI or manually create $CONFIG_DIR/remotes.d/${name}.conf to configure the destination."
                    ;;
                delete)
                    [[ -z "$name" ]] && die "destinations delete requires --name=NAME"
                    local conf="$CONFIG_DIR/remotes.d/${name}.conf"
                    [[ ! -f "$conf" ]] && die "Destination config not found: $conf"
                    rm -f "$conf"
                    log_info "Deleted destination config: $conf"
                    ;;
                show)
                    [[ -z "$name" ]] && die "destinations show requires --name=NAME"
                    load_remote "$name"
                    echo "=== Destination: $name ==="
                    echo ""
                    echo "Type:           $REMOTE_TYPE"
                    case "$REMOTE_TYPE" in
                        ssh)
                            echo "Host:           $REMOTE_HOST"
                            echo "Port:           $REMOTE_PORT"
                            echo "User:           $REMOTE_USER"
                            echo "Auth method:    $REMOTE_AUTH_METHOD"
                            if [[ "$REMOTE_AUTH_METHOD" == "key" ]]; then
                                echo "Key:            ${REMOTE_KEY:-(default)}"
                            else
                                echo "Password:       ****"
                            fi
                            echo "Sudo:           $REMOTE_SUDO"
                            echo "Base path:      $REMOTE_BASE"
                            ;;
                        local)
                            echo "Base path:      $REMOTE_BASE"
                            ;;
                        s3)
                            echo "Bucket:         ${S3_BUCKET:-}"
                            echo "Region:         ${S3_REGION:-}"
                            echo "Endpoint:       ${S3_ENDPOINT:-(default)}"
                            echo "Access Key:     ${S3_ACCESS_KEY_ID:+****}"
                            echo "Secret Key:     ${S3_SECRET_ACCESS_KEY:+****}"
                            echo "Base path:      $REMOTE_BASE"
                            ;;
                        gdrive)
                            echo "SA File:        ${GDRIVE_SERVICE_ACCOUNT_FILE:-}"
                            echo "Root Folder ID: ${GDRIVE_ROOT_FOLDER_ID:-(root)}"
                            echo "Base path:      $REMOTE_BASE"
                            ;;
                    esac
                    echo "Bandwidth:      ${BWLIMIT:-0} KB/s"
                    ;;
                test)
                    [[ -z "$name" ]] && die "destinations test requires --name=NAME"
                    validate_remote "$name"
                    test_remote_connection
                    echo "Destination '$name' is valid and reachable."
                    ;;
                disk-info-short)
                    [[ -z "$name" ]] && die "destinations disk-info-short requires --name=NAME"
                    load_remote "$name"
                    remote_disk_info_short
                    ;;
                *)
                    die "Unknown destinations action: $action (expected list|add|delete|show|test|disk-info-short)"
                    ;;
            esac
            ;;

        snapshots)
            local action="${SUBCMD_ARGS[0]:-list}"
            local target="" remote=""
            target=$(_parse_flag "--source" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            remote=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true

            case "$action" in
                help|--help|-h)
                    cat <<HELPEOF
Usage: gniza snapshots <action> [OPTIONS]

List or browse backup snapshots.

Actions:
  list [--source=NAME] [--destination=NAME]
                        List available snapshots (default)
  browse --source=NAME --snapshot=TS [--destination=NAME]
                        List all files in a specific snapshot
  help                  Show this help

Examples:
  gniza snapshots                                    List all snapshots
  gniza snapshots list --source=mysite               List snapshots for 'mysite'
  gniza snapshots browse --source=mysite --snapshot=2025-03-01_120000
HELPEOF
                    exit 0
                    ;;
                list)
                    if [[ -z "$remote" ]]; then
                        remote=$(list_remotes | head -1)
                        [[ -z "$remote" ]] && die "No destinations configured"
                    fi
                    _save_remote_globals
                    load_remote "$remote" || die "Failed to load destination: $remote"
                    if [[ -n "$target" ]]; then
                        list_remote_snapshots "$target"
                    else
                        local targets; targets=$(list_targets)
                        while IFS= read -r t; do
                            [[ -z "$t" ]] && continue
                            echo "=== $t ==="
                            list_remote_snapshots "$t" || true
                        done <<< "$targets"
                    fi
                    _restore_remote_globals
                    ;;
                browse)
                    [[ -z "$target" ]] && die "browse requires --source=NAME"
                    local snapshot=""
                    snapshot=$(_parse_flag "--snapshot" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
                    [[ -z "$snapshot" ]] && die "browse requires --snapshot=TS"
                    if [[ -z "$remote" ]]; then
                        remote=$(list_remotes | head -1)
                        [[ -z "$remote" ]] && die "No destinations configured"
                    fi
                    list_snapshot_contents "$target" "$snapshot" "$remote"
                    ;;
                *)
                    die "Unknown snapshots action: $action (expected list|browse)"
                    ;;
            esac
            ;;

        retention)
            if _has_flag "--help" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || _has_flag "-h" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || [[ "${SUBCMD_ARGS[0]:-}" == "help" ]]; then
                cat <<HELPEOF
Usage: gniza retention [OPTIONS]

Enforce snapshot retention policies. Deletes snapshots beyond the configured
retention count (oldest first, pinned snapshots are preserved).

Options:
  --source=NAME         Apply retention to a specific source
  --destination=NAME    Target a specific destination (default: first configured)
  --count=N             Override the default retention count
  --all                 Apply to all sources (default if no --source given)
  --help                Show this help

Examples:
  gniza retention                            Apply retention to all sources
  gniza retention --source=mysite            Apply retention to 'mysite'
  gniza retention --source=mysite --count=5  Keep only 5 snapshots
HELPEOF
                exit 0
            fi
            local target="" remote="" all=false count=""
            target=$(_parse_flag "--source" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            remote=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            count=$(_parse_flag "--count" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            _has_flag "--all" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" && all=true

            if [[ -z "$remote" ]]; then
                remote=$(list_remotes | head -1)
                [[ -z "$remote" ]] && die "No destinations configured"
            fi
            _save_remote_globals
            load_remote "$remote" || die "Failed to load destination: $remote"

            if [[ "$all" == "true" || -z "$target" ]]; then
                local targets; targets=$(list_targets)
                while IFS= read -r t; do
                    [[ -z "$t" ]] && continue
                    enforce_retention "$t" "$count"
                done <<< "$targets"
            else
                enforce_retention "$target" "$count"
            fi
            _restore_remote_globals
            ;;

        schedule)
            local action="${SUBCMD_ARGS[0]:-show}"
            case "$action" in
                help|--help|-h)
                    cat <<HELPEOF
Usage: gniza schedule <action>

Manage cron schedules for automated backups.

Actions:
  show                  Show current gniza cron entries (default)
  install               Install cron entries for all active schedules
  remove                Remove all gniza cron entries from crontab
  help                  Show this help

Examples:
  gniza schedule                         Show current cron entries
  gniza schedule install                 Install/update cron entries
  gniza schedule remove                  Remove all gniza cron entries
HELPEOF
                    exit 0
                    ;;
                install) install_schedules ;;
                show)    show_schedules ;;
                remove)  remove_schedules ;;
                *)       die "Unknown schedule action: $action (expected install|show|remove)" ;;
            esac
            ;;

        logs)
            if _has_flag "--help" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || _has_flag "-h" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" || [[ "${SUBCMD_ARGS[0]:-}" == "help" ]]; then
                cat <<HELPEOF
Usage: gniza logs [OPTIONS]

View backup logs.

Options:
  --last                Show the most recent backup log
  --tail=N              Show last N lines (use with --last)
  --help                Show this help

Examples:
  gniza logs                             List all log files
  gniza logs --last                      Show the most recent log
  gniza logs --last --tail=50            Show last 50 lines of the most recent log
HELPEOF
                exit 0
            fi
            local last=false tail_n=""
            _has_flag "--last" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}" && last=true
            tail_n=$(_parse_flag "--tail" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true

            local log_dir="${LOG_DIR}"
            if [[ "$last" == "true" ]]; then
                local latest; latest=$(ls -t "$log_dir"/gniza-*.log 2>/dev/null | head -1)
                if [[ -z "$latest" ]]; then
                    echo "No log files found."
                else
                    if [[ -n "$tail_n" ]]; then
                        tail -n "$tail_n" "$latest"
                    else
                        cat "$latest"
                    fi
                fi
            else
                ls -lt "$log_dir"/gniza-*.log 2>/dev/null || echo "No log files found."
            fi
            ;;

        scheduled-run)
            local sched_name="" target="" remote=""
            sched_name=$(_parse_flag "--schedule" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            target=$(_parse_flag "--source" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            remote=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            [[ -z "$sched_name" ]] && die "scheduled-run requires --schedule=NAME"

            # Load schedule config and check if active
            local sched_conf="$CONFIG_DIR/schedules.d/${sched_name}.conf"
            if [[ -f "$sched_conf" ]]; then
                local _sched_active=""
                _sched_active=$(grep -oP '^SCHEDULE_ACTIVE=["\x27]?\K[^"\x27]*' "$sched_conf" 2>/dev/null) || true
                if [[ "$_sched_active" == "no" ]]; then
                    log_info "Schedule '$sched_name' is inactive, skipping"
                    exit 0
                fi
                local _sched_retention=""
                _sched_retention=$(grep -oP '^RETENTION_COUNT=["\x27]?\K[^"\x27]*' "$sched_conf" 2>/dev/null) || true
                if [[ -n "$_sched_retention" ]]; then
                    export SCHEDULE_RETENTION_COUNT="$_sched_retention"
                fi
            fi

            # Register job in shared registry so web/TUI can track it
            # Skip if daemon already tracks this process
            local _job_id=""
            if [[ -z "${GNIZA_DAEMON_TRACKED:-}" ]]; then
                local _job_label="Scheduled: $sched_name"
                [[ -n "$target" ]] && _job_label+=" ($target"
                [[ -n "$remote" ]] && _job_label+=" → $remote"
                [[ -n "$target" ]] && _job_label+=")"
                _job_id=$(PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" "$GNIZA_DIR/lib/job_register.py" \
                    start "scheduled-run" "$_job_label" --log-file="${LOG_FILE:-}" --pid=$$ 2>/dev/null) || true
            fi
            [[ -n "${_job_id:-}" ]] && export GNIZA_JOB_ID="$_job_id"

            _finish_job_reg() {
                local _rc=$1
                local _st="success"
                (( _rc != 0 )) && _st="failed"
                if [[ -n "${_job_id:-}" ]]; then
                    PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" "$GNIZA_DIR/lib/job_register.py" \
                        finish "${_job_id}" "$_st" "$_rc" 2>/dev/null || true
                fi
            }

            trap '_gniza_exit_rc=$?; release_all_target_locks; _finish_job_reg $_gniza_exit_rc; _gniza_log_exit_trap $_gniza_exit_rc' EXIT

            local rc=0
            if [[ -n "$target" && "$target" == *,* ]]; then
                local IFS=','
                local names
                read -ra names <<< "$target"
                for t in "${names[@]}"; do
                    t="${t#"${t%%[![:space:]]*}"}"
                    t="${t%"${t##*[![:space:]]}"}"
                    [[ -z "$t" ]] && continue
                    backup_target "$t" "$remote" || rc=$?
                done
            elif [[ -n "$target" ]]; then
                backup_target "$target" "$remote" || rc=$?
            else
                backup_all_targets "$remote" || rc=$?
            fi

            # rc=2 means all targets were skipped (already running) — treat as success
            if (( rc == 2 )); then
                log_info "All targets already running, nothing to do"
                rc=0
            fi

            # Stamp LAST_RUN on success
            if (( rc == 0 )); then
                local conf="$CONFIG_DIR/schedules.d/${sched_name}.conf"
                if [[ -f "$conf" ]]; then
                    sed -i '/^LAST_RUN=/d' "$conf"
                    echo "LAST_RUN=\"$(date '+%Y-%m-%d %H:%M')\"" >> "$conf"
                fi
            fi

            # Send email notification
            local _status="success"
            if (( rc != 0 )); then _status="failed"; fi
            PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" -c "
import sys
from daemon.notify import send_job_notification
send_job_notification({
    'id': 'cron-$sched_name',
    'label': 'Scheduled: $sched_name',
    'kind': 'scheduled-run',
    'status': '$_status',
    'log_file': '${LOG_FILE:-}',
})
" 2>/dev/null || true

            exit "$rc"
            ;;

        health)
            local dest_flag="" json_flag=false
            dest_flag=$(_parse_flag "--destination" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            for arg in "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}"; do
                [[ "$arg" == "--json" ]] && json_flag=true
            done

            if [[ -n "$dest_flag" ]]; then
                _save_remote_globals
                load_remote "$dest_flag" || die "Failed to load destination: $dest_flag"
                if [[ "$json_flag" == "true" ]]; then
                    health_check_destination_json "$dest_flag"
                else
                    health_check_destination "$dest_flag"
                fi
                _restore_remote_globals
            else
                if [[ "$json_flag" == "true" ]]; then
                    health_check_all_json
                else
                    health_check_all
                fi
            fi
            ;;

        test-email)
            PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" -c "
from daemon.notify import send_test_notification
ok, msg = send_test_notification('email')
print(msg)
exit(0 if ok else 1)
"
            ;;

        test-notification)
            local channel="${2:-}"
            if [[ -z "$channel" ]]; then
                echo "Usage: gniza test-notification <channel>"
                echo "Channels: email, telegram, webhook, ntfy, healthcheck"
                exit 1
            fi
            case "$channel" in
                email|telegram|webhook|ntfy|healthcheck) ;;
                *) die "Invalid channel: $channel (must be email|telegram|webhook|ntfy|healthcheck)" ;;
            esac
            GNIZA_TEST_CHANNEL="$channel" PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" "$GNIZA_PYTHON" -c "
import os
from daemon.notify import send_test_notification
ok, msg = send_test_notification(os.environ['GNIZA_TEST_CHANNEL'])
print(msg)
exit(0 if ok else 1)
"
            ;;

        version)
            echo "gniza v${GNIZA4LINUX_VERSION}"
            ;;

        "")
            show_help
            ;;

        *)
            die "Unknown command: $SUBCOMMAND (see --help)"
            ;;
    esac
}

# ── Mode selection ───────────────────────────────────────────
if [[ "$SUBCOMMAND" == "web" ]]; then
    _web_action="${SUBCMD_ARGS[0]:-start}"
    case "$_web_action" in
        help|--help|-h)
            cat <<HELPEOF
Usage: gniza web <action> [OPTIONS]

Manage the web dashboard.

Actions:
  start [--port=PORT] [--host=HOST]
                        Start the web dashboard (default: port 2323, host 0.0.0.0)
  install-service       Install as a systemd service (auto-starts on boot)
  remove-service        Stop and remove the systemd service
  status                Show service status
  reset-password        Generate a new random login password
  help                  Show this help

Examples:
  gniza web                              Start the web dashboard
  gniza web start --port=8080            Start on a custom port
  gniza web install-service              Install as systemd service
  gniza web status                       Check service status
  gniza web reset-password               Generate a new password
HELPEOF
            exit 0
            ;;
        start)
            _web_port="" _web_host=""
            _web_port=$(_parse_flag "--port" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            _web_host=$(_parse_flag "--host" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            _web_args=()
            [[ -n "$_web_port" ]] && _web_args+=(--port="$_web_port")
            [[ -n "$_web_host" ]] && _web_args+=(--host="$_web_host")
            PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" exec "$GNIZA_PYTHON" -m web "${_web_args[@]}"
            ;;
        install-service)
            if [[ $EUID -eq 0 ]]; then
                _service_src="$GNIZA_DIR/etc/gniza-web.service"
                _service_dst="/etc/systemd/system/gniza-web.service"
                if [[ ! -f "$_service_src" ]]; then
                    die "Service file not found: $_service_src"
                fi
                cp "$_service_src" "$_service_dst"
                systemctl daemon-reload
                systemctl enable gniza-web
                systemctl restart gniza-web
            else
                _user_service_dir="$HOME/.config/systemd/user"
                mkdir -p "$_user_service_dir"
                cat > "$_user_service_dir/gniza-web.service" <<SVCEOF
[Unit]
Description=GNIZA Web Dashboard
After=network.target

[Service]
Type=simple
ExecStart=$GNIZA_DIR/bin/gniza web start
WorkingDirectory=$GNIZA_DIR
Environment=GNIZA_DIR=$GNIZA_DIR
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
SVCEOF
                systemctl --user daemon-reload
                systemctl --user enable gniza-web
                systemctl --user restart gniza-web
            fi
            echo "GNIZA web service installed and started."
            echo "Access the dashboard at http://$(hostname -I | awk '{print $1}'):2323"
            ;;
        remove-service)
            if [[ $EUID -eq 0 ]]; then
                systemctl stop gniza-web 2>/dev/null || true
                systemctl disable gniza-web 2>/dev/null || true
                rm -f /etc/systemd/system/gniza-web.service
                systemctl daemon-reload
            else
                systemctl --user stop gniza-web 2>/dev/null || true
                systemctl --user disable gniza-web 2>/dev/null || true
                rm -f "$HOME/.config/systemd/user/gniza-web.service"
                systemctl --user daemon-reload 2>/dev/null || true
            fi
            echo "GNIZA web service removed."
            ;;
        status)
            if [[ $EUID -eq 0 ]]; then
                systemctl status gniza-web 2>/dev/null || echo "GNIZA web service is not installed."
            else
                systemctl --user status gniza-web 2>/dev/null || echo "GNIZA web service is not installed."
            fi
            ;;
        reset-password)
            _conf="$CONFIG_DIR/gniza.conf"
            _new_key=$("$GNIZA_PYTHON" -c 'import secrets; print(secrets.token_urlsafe(32))')
            # Create config file if it doesn't exist
            mkdir -p "$(dirname "$_conf")"
            touch "$_conf"
            if grep -q "^WEB_API_KEY=" "$_conf" 2>/dev/null; then
                sed -i "s|^WEB_API_KEY=.*|WEB_API_KEY=\"${_new_key}\"|" "$_conf"
            else
                echo "WEB_API_KEY=\"${_new_key}\"" >> "$_conf"
            fi
            echo "Password reset."
            echo ""
            echo "  New password: $_new_key"
            echo ""
            # Restart web service if running
            if [[ $EUID -eq 0 ]]; then
                systemctl restart gniza-web 2>/dev/null && echo "Web service restarted." || true
            else
                systemctl --user restart gniza-web 2>/dev/null && echo "Web service restarted." || true
            fi
            ;;
        *) die "Unknown web action: $_web_action (expected start|install-service|remove-service|reset-password|status)" ;;
    esac
elif [[ "$SUBCOMMAND" == "daemon" ]]; then
    _daemon_action="${SUBCMD_ARGS[0]:-start}"
    case "$_daemon_action" in
        help|--help|-h)
            cat <<HELPEOF
Usage: gniza daemon <action> [OPTIONS]

Manage the background health daemon.

Actions:
  start [--interval=N]  Start the daemon in foreground (default interval: from config or 10s)
  install-service       Install as a systemd service (auto-starts on boot)
  remove-service        Stop and remove the systemd service
  status                Show service status
  help                  Show this help

Examples:
  gniza daemon                           Start the daemon
  gniza daemon start --interval=30       Start with 30s check interval
  gniza daemon install-service           Install as systemd service
  gniza daemon status                    Check service status
HELPEOF
            exit 0
            ;;
        start)
            _daemon_interval=""
            _daemon_interval=$(_parse_flag "--interval" "${SUBCMD_ARGS[@]+"${SUBCMD_ARGS[@]}"}") || true
            _daemon_args=(--foreground)
            [[ -n "$_daemon_interval" ]] && _daemon_args+=(--interval="$_daemon_interval")
            PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" exec "$GNIZA_PYTHON" -m daemon "${_daemon_args[@]}"
            ;;
        install-service)
            if [[ $EUID -eq 0 ]]; then
                _service_src="$GNIZA_DIR/etc/gniza-daemon.service"
                _service_dst="/etc/systemd/system/gniza-daemon.service"
                if [[ ! -f "$_service_src" ]]; then
                    die "Service file not found: $_service_src"
                fi
                cp "$_service_src" "$_service_dst"
                systemctl daemon-reload
                systemctl enable gniza-daemon
                systemctl restart gniza-daemon
            else
                _user_service_dir="$HOME/.config/systemd/user"
                mkdir -p "$_user_service_dir"
                cat > "$_user_service_dir/gniza-daemon.service" <<SVCEOF
[Unit]
Description=GNIZA Background Health Daemon
After=network.target

[Service]
Type=simple
ExecStart=$GNIZA_DIR/bin/gniza daemon start
WorkingDirectory=$GNIZA_DIR
Environment=GNIZA_DIR=$GNIZA_DIR
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
SVCEOF
                systemctl --user daemon-reload
                systemctl --user enable gniza-daemon
                systemctl --user restart gniza-daemon
            fi
            echo "GNIZA daemon service installed and started."
            ;;
        remove-service)
            if [[ $EUID -eq 0 ]]; then
                systemctl stop gniza-daemon 2>/dev/null || true
                systemctl disable gniza-daemon 2>/dev/null || true
                rm -f /etc/systemd/system/gniza-daemon.service
                systemctl daemon-reload
            else
                systemctl --user stop gniza-daemon 2>/dev/null || true
                systemctl --user disable gniza-daemon 2>/dev/null || true
                rm -f "$HOME/.config/systemd/user/gniza-daemon.service"
                systemctl --user daemon-reload 2>/dev/null || true
            fi
            echo "GNIZA daemon service removed."
            ;;
        status)
            if [[ $EUID -eq 0 ]]; then
                systemctl status gniza-daemon 2>/dev/null || echo "GNIZA daemon service is not installed."
            else
                systemctl --user status gniza-daemon 2>/dev/null || echo "GNIZA daemon service is not installed."
            fi
            ;;
        *) die "Unknown daemon action: $_daemon_action (expected start|install-service|remove-service|status)" ;;
    esac
elif [[ "$SUBCOMMAND" == "update" || "$SUBCOMMAND" == "upgrade" ]]; then
    _update_script="$GNIZA_DIR/scripts/update.sh"
    if [[ -f "$_update_script" ]]; then
        exec bash "$_update_script" "${SUBCMD_ARGS[@]}"
    else
        die "Update script not found: $_update_script"
    fi
elif [[ "$SUBCOMMAND" == "uninstall" ]]; then
    _uninstall_script="$GNIZA_DIR/scripts/uninstall.sh"
    if [[ -f "$_uninstall_script" ]]; then
        exec bash "$_uninstall_script"
    else
        die "Uninstall script not found: $_uninstall_script"
    fi
elif [[ -n "$SUBCOMMAND" ]]; then
    # Explicit subcommand: always CLI
    run_cli
elif [[ "$FORCE_CLI" == "true" ]]; then
    run_cli
elif "$GNIZA_PYTHON" -c "import textual" 2>/dev/null && [[ -t 1 ]]; then
    # Python Textual TUI mode
    PYTHONPATH="$GNIZA_DIR:${PYTHONPATH:-}" exec "$GNIZA_PYTHON" -m tui "$@"
else
    # Fallback to CLI help
    run_cli
fi
